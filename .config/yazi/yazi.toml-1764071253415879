[opener]
play = [
    { run = 'mpv "$@"', orphan = true, for = "unix" },
]

edit = [
    { run = '$EDITOR "$@"', block = true, for = "unix" },
]

open = [
    { run = 'xdg-open "$@"', desc = "Open" }
]

pdf = [
    { run = 'zathura "$@"', desc = "Open PDF", block = false, for = "unix" }
]


[manager]
openers = [
    { name = "pdf", extensions = ["pdf"] }
]
