{
    "custom/arch": {
        "format": "≤░μΘ",
        "tooltip": true,
        "tooltip-format": "btw"
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{name}",
        "format-icons": {
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        },
    },
  "wireplumber": {
    "format": "{icon}  {volume}%",
    "format-muted": "ΎΑο  {volume}%",                   // Muted speaker
    "format-bluetooth": "ΎΛΦ {icon}  {volume}% ({format_source})",
    "format-bluetooth-muted": "ΎΛΦ ΎΑο  {volume}% ({format_source})",
    "format-source": "ΎΕ░  {volume}%",                 // Microphone
    "format-source-muted": "ΎΕ▒   {volume}%",           // Muted mic
    "format-icons": {
      "headphone": "ΎθΛ",       // Headphones
      "hands-free": "ΎθΛ",      // Earbuds / hands-free
      "headset": "ΎθΛ",          // Headset
      "phone": "ΎΓΧ",            // Phone
      "portable": "ΎΓΧ",         // Tablet / portable
      "car": "ΎΗ╣",              // Car audio
      "default": [
        "ΎΑπ",                 // Low volume
        "ΎΑρ",                 // Medium volume
        "ΎΑρ"                  // High volume
      ]
    },
    "on-click": "pavucontrol",
    "volume-ranges": [
      { "max": 30, "icon": "ΎΑο" },
      { "max": 65, "icon": "ΎΑπ" },
      { "max": 100, "icon": "ΎΑρ" }
    ]
  },
    "network": {
        "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        "format-ethernet": "≤░ΙΑ",
        "format-disconnected": "Disconnected έγι",
        "on-click": "sh ~/scripts/rofi-wifi-menu/rofi-wifi-menu.sh"
    },
    "cpu": {
        "format": "ΎΜδ  {usage}%",
        "tooltip": true
    },
    "memory": {
    "format": "Ό┐Ζ  {used} GiB",
    "tooltip": true
    },
    "hyprland/language": {
       "format": "ΎΓυ  {}",
       "format-en": "EN",
       "format-pt": "PT"
    },
    "clock": {
        "format": "{:%H:%M | %e %B} ",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%Y}"
    }
}
