{
    "layer": "top",
    "position": "top",
    "height": 24,
    "spacing": 5,

    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "pulseaudio",
        "custom/power-profile",
        "idle_inhibitor",
        "battery",
        "tray"
    ],

    "hyprland/workspaces": {
        "format": "<span size='larger'>{icon}</span>",
        "on-click": "activate",
        "format-icons": {
            "active": "\uf444",
            "default": "\uf4c3"
        }
    },

    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "format-alt": "{:%A, %d %B %Y %H:%M}",
        "interval": 60,
        "tooltip": true,
        "tooltip-format": "{:%A, %d %B %Y\n%H:%M}"
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "َ°‌ں",
        "format-icons": {
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "scroll-step": 5,
        "max-volume": 100,
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip": true,
        "tooltip-format": "{desc}\nVolume: {volume}%"
    },

    "memory": {
        "interval": 30,
        "format": "\uf4bc  {used:0.1f}G"
    },

    "network": {
        "format": "{icon}",
        "format-wifi": "{icon}",
        "format-ethernet": "َ°ˆ€",
        "format-disconnected": "َ°¤®",

        "format-icons": [
            "َ°¤¯",  // very low
            "َ°¤ں",
            "َ°¤¢",
            "َ°¤¥",
            "َ°¤¨"   // excellent
        ],

        "tooltip": true,
        "tooltip-format-wifi": "{essid}\nSignal: {signalStrength}%",
        "tooltip-format-ethernet": "Ethernet: {ifname}",
        "tooltip-format-disconnected": "Disconnected"
    },

    "bluetooth": {
        "format": "{icon}",
        "tooltip": true,

        "format-icons": {
            "enabled": "َ°‚¯",
            "disabled": "َ°‚²",
            "connected": "َ°‚±",
            "default": "َ°‚¯"
        },

        "tooltip-format": "{controller_alias}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "â€¢ {device_alias}"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 16
    },

    "custom/power-profile": {
        "exec": "~/.config/waybar/scripts/power-profile-tlp.sh",
        "interval": 10,
        "return-type": "json",

        "format": "{icon}",
        "tooltip": true,

        "format-icons": {
            "performance": "َ°“…",   // rocket / speed
            "balanced": "َ°ˆگ",      // sliders / balance
            "power-saver": "َ°Œھ",   // leaf / eco
            "default": "َ°چ›"
        },

        "on-click": "~/.config/waybar/scripts/power-profile-tlp.sh toggle"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "\udb80\udd76",
            "deactivated": "\udb83\udfaa"
        }
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },

        "format": "{icon}",
        "format-charging": "َ°‚„",
        "format-plugged": "َ°‚„",
        "format-alt": "{capacity}%",

        "format-icons": [
            "َ°‚ژ",
            "َ°پ؛",
            "َ°پ»",
            "َ°پ¼",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],

        "tooltip": true,
        "tooltip-format": "Battery: {capacity}%"
    }
}
